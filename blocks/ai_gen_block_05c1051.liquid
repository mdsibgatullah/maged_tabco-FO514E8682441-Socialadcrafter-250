{% doc %}
  @prompt
    Give me a section wodth css control 1400px-full width, a heding >> size & weight control and heading border full sec width css control, Under collection image and title centre align, image radius css control and title size & weight css control give. section padding css control give, give collection title and image separate option, heading 1px solid border
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-section-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    display: block;
  }

  .ai-collection-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-heading-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    position: relative;
  }

  .ai-collection-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_border_spacing }}px;
  }

  .ai-collection-heading-border-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.heading_border_color }};
  }

  .ai-collection-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }

  .ai-collection-item-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-collection-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: 15px;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-collection-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-collection-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-collection-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    text-decoration: none;
  }

  .ai-collection-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-link-{{ ai_gen_id }}:hover .ai-collection-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .ai-collection-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-collection-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }
  }
{% endstyle %}

<collection-section-{{ ai_gen_id }}
  class="ai-collection-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-collection-heading-wrapper-{{ ai_gen_id }}">
        <h2 class="ai-collection-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% if block.settings.show_heading_border %}
          <div class="ai-collection-heading-border-{{ ai_gen_id }}"></div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-collection-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'collection_image_' | append: i
          assign title_key = 'collection_title_' | append: i
          assign url_key = 'collection_url_' | append: i
          
          assign collection_image = block.settings[image_key]
          assign collection_title = block.settings[title_key]
          assign collection_url = block.settings[url_key]
        %}

        {% if collection_image != blank or collection_title != blank %}
          <div class="ai-collection-item-{{ ai_gen_id }}">
            <a href="{{ collection_url }}" class="ai-collection-link-{{ ai_gen_id }}">
              <div class="ai-collection-image-wrapper-{{ ai_gen_id }}">
                {% if collection_image %}
                  <img
                    src="{{ collection_image | image_url: width: 600 }}"
                    alt="{{ collection_title | escape }}"
                    class="ai-collection-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-collection-image-placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              {% if collection_title != blank %}
                <h3 class="ai-collection-title-{{ ai_gen_id }}">{{ collection_title }}</h3>
              {% endif %}
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</collection-section-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('collection-section-{{ ai_gen_id }}', CollectionSection{{ ai_gen_id }});
  })();
</script>

