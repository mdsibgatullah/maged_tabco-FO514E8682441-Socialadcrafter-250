{%- comment -%}
  LAZY SCRIPTS SNIPPET for Be3ah.com
  Optimizes page speed by deferring and lazy-loading non-critical JS
  Created for improved LCP, TBT, and SEO performance
{%- endcomment -%}

<!-- ✅ Lazy Script Loader Function -->
<script>
  window.deferScript = function(src, delay = 3000) {
    setTimeout(function() {
      var s = document.createElement('script');
      s.src = src;
      s.async = true;
      document.body.appendChild(s);
    }, delay);
  };
</script>

<!-- ✅ Lazy-load 3rd-party scripts after DOM is ready -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // --- Google Tag Manager (Main unified container) ---
    {% comment %} deferScript("https://www.googletagmanager.com/gtag/js?id=GTM-MHG4BN75", 2000); {% endcomment %}

    // --- Facebook Pixel ---
    deferScript("https://connect.facebook.net/en_US/fbevents.js", 4000);

    // --- Vendor marketplace (Webkul) ---
    deferScript("https://sp-seller.webkul.com/js/seller_profile_tag.js?shop=6v1nfd-wh.myshopify.com", 5000);


  });
</script>

<!-- ✅ Lazy-load jQuery only when required -->
{%- if template contains 'vendor' or template contains 'collection' -%}
<script>
  deferScript("https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js", 3000);
</script>
{%- endif -%}