<script src="{{ 'ilm-filter.js' |  asset_url }}" defer></script>
<style>
  #ilm_filter {
    .ilm_collection_filter_head {
      margin-bottom: 15px;
    }
    .ilm_filter_title {
      background-color: #fcc216;
      padding: 1px 10px;
      margin: 0;
      cursor: pointer;
      gap: 20px;
      position: relative;
      span {
        position: absolute;
        width: 8px;
        height: 8px;
        border: 2px solid black;
        border-top: 0;
        border-left: 0;
        transform: rotate(45deg);
        transition: .4s;
        display: block;
        right: 15px;
        bottom: 15px;
      }
    }

    .ilm_filter_sublist {
      list-style: none;
      padding: 0 0 0 15px;
      margin-top: 15px;
      height: 100%;
    }
    .ilm_collection_filter_head.deActive .ilm_filter_sublist {
      height: 0px;
      overflow: hidden;
      margin-top: 0px;
    }
    .ilm_collection_filter_head.deActive .ilm_filter_title span {
        transform: rotate(-45deg);
      }

    .ilm_sublist_content {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 5px;
    }

    .ilm_sublist_content input[type='checkbox'] {
      display: inline-block !important;
      position: relative !important;
      width: 16px !important;
      height: 16px !important;
      min-width: 16px !important;
      clip: auto !important;
      overflow: visible !important;
      padding: 0 !important;
      border: 1px solid #ccc !important;
      -webkit-appearance: checkbox !important;
      appearance: checkbox !important;
      cursor: pointer;
      flex-shrink: 0;
    }

    .ilm_sublist_content label {
      cursor: pointer;
      line-height: 1.4;
    }
  }
</style>
<div class="ilm_collection_filter" id="ilm_filter">
  <div class="ilm_collection_filter_content">
    <ul style="list-style: none; padding: 0;">
      {% for filter in collection.filters %}
        <li class="ilm_collection_filter_head">
          <h3 class="ilm_filter_title">{{ filter.label }} 
            <span></span>
          </h3>

        {% if filter.type == 'list' or filter.type == 'boolean' %}
          <ul class="ilm_filter_sublist">
            {% for value in filter.values %}
              <li class="ilm_sublist_content">
                <input
                  class="ilm_sublist_check"
                  type="checkbox"
                  id="{{ filter.label }}-{{ value.label | handle }}"
                  name="{{ filter.label | handle }}"
                  value="{{ value.value | handle }}"
                  data-add-url="{{ value.url_to_add }}"
                  data-remove-url="{{ value.url_to_remove }}"
                  {% if value.active %}
                    checked
                  {% endif %}
                >
                <label for="{{ filter.label }}-{{ value.label | handle }}">
                  {{ value.label | link_to: value.url_to_add }} ({{ value.count }})
                </label>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>
