<div class="product-categories-section">
  {% if section.settings.heading != blank %}
    <div class="product-categories-heading-wrap">
      <h2 class="product-categories-heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="product-categories-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a href="{{ block.settings.link | default: '#' }}" class="product-category-item">
          <div class="product-category-icon-wrap">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 200 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="100"
                height="100"
                class="product-category-icon"
              >
            {% else %}
              <div class="product-category-icon-placeholder"></div>
            {% endif %}
          </div>
          <p class="product-category-title">{{ block.settings.title }}</p>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% style %}
  .product-categories-section {
    max-width: {{ section.settings.container_width | default: 1200 }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top | default: 30 }}px {{ section.settings.padding_horizontal | default: 20 }}px {{ section.settings.padding_bottom | default: 30 }}px;
    border: {{ section.settings.show_border }} solid {{ section.settings.border_color }};
  }

  .product-categories-heading-wrap {
    text-align: center;
    /* border: 1px solid {{ section.settings.border_color | default: '#e0e0e0' }}; */
    border-radius: 4px;
    padding: 14px 20px;
    margin-bottom: 30px;
    /* box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2); */
  }

  .product-categories-heading {
    font-size: {{ section.settings.heading_size | default: 22 }}px;
    font-weight: 500;
    margin: 0;
    color: {{ section.settings.heading_color | default: '#1a1a1a' }};
  }

  .product-categories-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 8 }}, 1fr);
    gap: 20px;
    text-align: center;
  }

  .product-category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .product-category-item:hover {
    transform: translateY(-20px);
  }

  .product-category-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .product-category-icon {
    width: {{ section.settings.icon_size | default: 110 }}px;
    height: {{ section.settings.icon_size | default: 110 }}px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.icon_border_color | default: '#f0a93b' }};
    object-fit: contain;
    padding: 10px;
  }

  .product-category-icon-placeholder {
    width: 60%;
    height: 60%;
    background: #e8e8e8;
    border-radius: 6px;
  }

  .product-category-title {
    font-size: {{ section.settings.title_size | default: 15 }}px;
    font-weight: 600;
    margin: 0;
    color: {{ section.settings.title_color | default: '#1a1a1a' }};
    line-height: 1.3;
  }
@media(max-width:1500px){
  .product-category-icon {
    width: auto;
    height: auto;
    border-radius: 50%;
    border: 2px solid {{ section.settings.icon_border_color | default: '#f0a93b' }};
    object-fit: contain;
    padding: 10px;
  }
}
  @media screen and (max-width: 1024px) {
    .product-categories-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 4 }}, 1fr);
    }
  }

  @media screen and (max-width: 600px) {
    .product-categories-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile | default: 2 }}, 1fr);
    }
    .product-category-icon-wrap {
      width: 120px;
      height: 120px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Product categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Products at Next Computer Store"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "select",
      "id": "show_border",
      "label": "Show outer section border",
      "options": [
        { "value": "none", "label": "No" },
        { "value": "1px", "label": "Yes" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon circle size (px)",
      "min": 60,
      "max": 180,
      "step": 5,
      "default": 110
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon circle border color",
      "default": "#f0a93b"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max section width (px)",
      "min": 800,
      "max": 2500,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Gaming PC Components" } },
        { "type": "category", "settings": { "title": "Gaming Laptops" } },
        { "type": "category", "settings": { "title": "Laptops" } },
        { "type": "category", "settings": { "title": "Tablets" } },
        { "type": "category", "settings": { "title": "Gaming Monitors" } },
        { "type": "category", "settings": { "title": "Gaming PC / Desktop" } },
        { "type": "category", "settings": { "title": "Gaming PC Accessories" } },
        { "type": "category", "settings": { "title": "Display Products" } }
      ]
    }
  ]
}
{% endschema %}
