{{ 'triple-banner.css' | asset_url | stylesheet_tag }}

<div class="triple-banner-section full-width" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background-color:{{ section.settings.bg_color }}; --pad-desktop:{{ section.settings.padding_desktop }}px; --pad-laptop:{{ section.settings.padding_laptop }}px; --pad-mobile:{{ section.settings.padding_mobile }}px;">
  <div class="triple-banner-container" style="--banner-gap:{{ section.settings.gap }}px;">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'banner' %}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="triple-banner-item{% if section.settings.enable_shadow %} has-shadow{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="triple-banner-image-wrap">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 400 }} 400w,
                    {{ block.settings.image | image_url: width: 800 }} 800w,
                    {{ block.settings.image | image_url: width: 1200 }} 1200w
                  "
                  sizes="(max-width: 749px) 100vw, 33vw"
                  alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="triple-banner-img"
                >
              {% else %}
                <div class="triple-banner-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {% endif %}
            </div>
          </a>
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Triple Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Enable box shadow on banners",
      "default": true
    },
    {
      "type": "header",
      "content": "Side padding"
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "label": "Desktop padding (left/right)",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_laptop",
      "label": "Laptop/Tablet padding (left/right)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Mobile padding (left/right)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Vertical spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between banners",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Alt text fallback (used if image has no alt)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Triple Banner",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}
